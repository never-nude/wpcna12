---
layout: layouts/base.njk
title: White Plains History
metaDescription: Historical context connected to White Plains neighborhoods, civic life, and current history-related events.
---
{% from "components/macros.njk" import neighborhoodCard, eventCard %}

<section class="page-hero">
  <div class="wrap">
    <p class="eyebrow">White Plains</p>
    <h1>White Plains history</h1>
    <p>A short guide to historical threads connected to White Plains neighborhoods and civic life.</p>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="spotlight">
      <div>
        <p class="eyebrow">Scope</p>
        <h2>Historical context in the guide</h2>
        {% for paragraph in history.overview %}
          <p>{{ paragraph }}</p>
        {% endfor %}
      </div>

      <div class="spotlight-card">
        <p class="eyebrow">Neighborhood Guide</p>
        <h3>Keep exploring White Plains</h3>
        <p>The neighborhood guide brings together the parts of White Plains where local history, civic life, and neighborhood identity overlap most clearly.</p>
        <a class="btn btn-primary btn-block resource-card-action" href="{{ '/neighborhoods/' | withPrefix }}">Open the neighborhood guide</a>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="wrap">
    <div class="section-header">
      <div>
        <h2>Historic threads in the neighborhood guide</h2>
        <p>These neighborhood pages include visible historical context tied to White Plains.</p>
      </div>
      <a class="link-arrow" href="{{ '/neighborhoods/' | withPrefix }}">All neighborhoods</a>
    </div>

    <div class="card-grid">
      {% for neighborhood in history.featuredNeighborhoods %}
        {{ neighborhoodCard(neighborhood) }}
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section-alt">
  <div class="wrap">
    <div class="section-header">
      <div>
        <h2>History-related events on the calendar</h2>
        <p>Current listings from approved site sources that touch on local history, preservation, or genealogy.</p>
      </div>
      <a class="link-arrow" href="{{ '/events/' | withPrefix }}">All events</a>
    </div>

    {% if history.historyEvents.length %}
      <div class="card-grid">
        {% for event in history.historyEvents %}
          {{ eventCard(event) }}
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">
        <h3>No history-focused events are listed right now.</h3>
        <p>Check back later or browse the full events calendar.</p>
      </div>
    {% endif %}
  </div>
</section>
