<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <p class="footer-brand">{{ site.shortName }}</p>
      <p>{{ site.mission }}</p>
    </div>
    <div>
      <h3>Contact</h3>
      <ul>
        <li>{{ site.location }}</li>
        <li><a href="{{ '/about/#contact-form' | withPrefix }}">Use the contact form</a></li>
      </ul>
    </div>
    <div>
      <h3>WPCNA</h3>
      <ul>
        <li><a href="{{ '/agendas/' | withPrefix }}">Meeting agendas &amp; minutes</a></li>
        <li><a href="{{ '/workshops/' | withPrefix }}">CNA Workshop Handbook</a></li>
        <li><a href="{{ '/community-posting/' | withPrefix }}">Community posting</a></li>
        <li><a href="{{ '/neighborhood-map/' | withPrefix }}">Neighborhood map</a></li>
        <li><a href="{{ '/about/' | withPrefix }}">About WPCNA</a></li>
      </ul>
    </div>
    <div>
      <h3>Community calendars</h3>
      <ul>
        {% for link in site.communityChannels %}
          <li><a href="{{ link.url }}" target="_blank" rel="noopener">{{ link.label }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>{{ site.footerNote }}</p>
  </div>
</footer>
